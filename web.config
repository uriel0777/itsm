<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <handlers>
      <!-- Ensure the scriptProcessor matches the actual Python path on the Windows Server -->
      <add name="Python FastCGI" 
           path="*" 
           verb="*" 
           modules="FastCgiModule" 
           scriptProcessor="C:\Python311\python.exe|C:\Python311\Lib\site-packages\wfastcgi.py" 
           resourceType="Unspecified" 
           requireAccess="Script" />
    </handlers>
  </system.webServer>
  
  <appSettings>
    <!-- Points to the Flask app instance in app.py -->
    <add key="WSGI_HANDLER" value="app.app" />
    <!-- Paths to the application source code -->
    <add key="PYTHONPATH" value="C:\inetpub\wwwroot\itsm_app" />
  </appSettings>
</configuration>
